# =============================================================================
# Africa Intelligence Platform — Environment Variables
# Copy this file to .env (root) and apps/api/.env, fill in real values
# =============================================================================

# --- Database (Timescale Cloud or local PostgreSQL + TimescaleDB) ---
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/africa_platform
DATABASE_URL_SYNC=postgresql://user:password@localhost:5432/africa_platform

# --- Redis (Upstash or local Redis) ---
REDIS_URL=redis://localhost:6379/0

# --- OpenAI ---
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o

# --- Object Storage (Cloudflare R2 / AWS S3) ---
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_BUCKET_NAME=africa-platform
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- OpenSearch ---
OPENSEARCH_URL=https://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=

# --- Auth (Auth.js / OIDC) ---
AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
AUTH_URL=http://localhost:3000

# --- App ---
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000
ENVIRONMENT=development
LOG_LEVEL=info

# --- Data Sources (Phase 1+) ---
# WORLD_BANK_API_KEY=
# UN_SDG_API_KEY=
# ACLED_API_KEY=
# ACLED_EMAIL=
# RELIEFWEB_API_KEY=
