{
  "framework": "nextjs",
  "buildCommand": "pnpm run build",
  "installCommand": "pnpm install",
  "outputDirectory": ".next",
  "crons": [
    { "path": "/api/ingest",              "schedule": "0 6 * * *"   },
    { "path": "/api/ingest/history",      "schedule": "30 6 * * *"  },
    { "path": "/api/briefs/generate",     "schedule": "0 7 * * *"   },
    { "path": "/api/startups/discover",   "schedule": "0 8 * * 1"   },
    { "path": "/api/startups/briefs",     "schedule": "30 8 * * 1"  }
  ]
}
